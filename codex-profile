#!/usr/bin/env bash
# codex-profile: switch between multiple Codex CLI accounts via CODEX_HOME
#
# Each profile is an isolated CODEX_HOME directory under ~/.codex-profiles/<name>.
# Existing profiles are never touched. New profiles start empty and trigger
# Codex's normal OAuth flow on first launch.

set -euo pipefail

PROFILES_DIR="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}"
STATE_FILE="$PROFILES_DIR/.active"
SHARED_DIR="$PROFILES_DIR/_shared"
SHARED_CONFIG="$SHARED_DIR/config.toml"

# Files we share across all profiles via symlink.
# config.toml: MCP servers, model defaults, approval policies, etc.
# (Authentication state in auth.json is intentionally NOT shared.)
SHARED_FILES=("config.toml")
PROFILE_NAME_PATTERN='^[a-zA-Z0-9_-]+$'

# --- colors (only when stdout is a tty) -------------------------------------
if [[ -t 1 ]]; then
    C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
    C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'
    C_CYAN=$'\033[36m'; C_RESET=$'\033[0m'
else
    C_BOLD=""; C_DIM=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_CYAN=""; C_RESET=""
fi

die()  { echo "${C_RED}error:${C_RESET} $*" >&2; exit 1; }
info() { echo "${C_CYAN}->${C_RESET} $*"; }
ok()   { echo "${C_GREEN}ok${C_RESET}  $*"; }

ensure_dirs() {
    mkdir -p "$PROFILES_DIR"
}

is_valid_profile_name() {
    local name="${1:-}"
    [[ -n "$name" ]] || return 1
    [[ "$name" != "_shared" ]] || return 1
    [[ "$name" =~ $PROFILE_NAME_PATTERN ]]
}

validate_profile_name() {
    local name="${1:-}"
    is_valid_profile_name "$name" || die "name must be alphanumeric / dash / underscore and not reserved"
}

warn_invalid_profile_dir() {
    echo "${C_YELLOW}warning:${C_RESET} skipping invalid profile directory: $1" >&2
}

profile_path() {
    validate_profile_name "$1"
    echo "$PROFILES_DIR/$1"
}

profile_exists() {
    validate_profile_name "$1"
    [[ -d "$(profile_path "$1")" ]]
}

profile_has_auth() {
    validate_profile_name "$1"
    [[ -f "$(profile_path "$1")/auth.json" ]]
}

active_profile() {
    [[ -f "$STATE_FILE" ]] || return 0

    local active
    active="$(cat "$STATE_FILE" 2>/dev/null || true)"
    [[ -n "$active" ]] || return 0
    if ! is_valid_profile_name "$active"; then
        die "active profile state is invalid: $active"
    fi
    echo "$active"
}

write_active_profile() {
    local name="$1"
    validate_profile_name "$name"
    ensure_dirs

    local tmp
    tmp="$(mktemp "$PROFILES_DIR/.active.tmp.XXXXXX")"
    if ! printf '%s\n' "$name" > "$tmp"; then
        rm -f "$tmp"
        die "failed to write active profile state"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    if ! mv -f "$tmp" "$STATE_FILE"; then
        rm -f "$tmp"
        die "failed to update active profile state"
    fi
}

# --- shared config helpers --------------------------------------------------

ensure_shared() {
    mkdir -p "$SHARED_DIR"
    [[ -f "$SHARED_CONFIG" ]] || touch "$SHARED_CONFIG"
}

# Status of a shared file inside a profile:
#   "linked"  : symlink pointing at the shared file
#   "local"   : regular file (overrides shared)
#   "missing" : file does not exist
#   "broken"  : symlink to wrong/non-existent target
shared_file_status() {
    local profile="$1" filename="$2"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    if [[ -L "$path" ]]; then
        local actual
        actual="$(readlink -f "$path" 2>/dev/null || true)"
        local expected
        expected="$(readlink -f "$target" 2>/dev/null || true)"
        if [[ -n "$actual" && "$actual" == "$expected" ]]; then
            echo "linked"
        else
            echo "broken"
        fi
    elif [[ -f "$path" ]]; then
        echo "local"
    else
        echo "missing"
    fi
}

# Link a profile's file to the shared one.
# If the profile already has a regular file, refuse unless --force.
link_shared_file() {
    local profile="$1" filename="$2" force="${3:-}"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    ensure_shared
    [[ -f "$target" ]] || touch "$target"

    local status
    status="$(shared_file_status "$profile" "$filename")"

    case "$status" in
        linked)
            return 0  # already linked, no-op
            ;;
        local)
            if [[ "$force" != "--force" ]]; then
                echo "${C_YELLOW}skip:${C_RESET} $profile/$filename is a local file (use --force to overwrite)" >&2
                return 1
            fi
            rm -f "$path"
            ;;
        broken)
            rm -f "$path"
            ;;
        missing)
            : # nothing to clean
            ;;
    esac

    ln -s "$target" "$path"
}

# Detach a profile's file from shared and make it a private copy.
unlink_shared_file() {
    local profile="$1" filename="$2"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    local status
    status="$(shared_file_status "$profile" "$filename")"

    case "$status" in
        linked)
            rm -f "$path"
            if [[ -f "$target" ]]; then
                cp "$target" "$path"
            else
                touch "$path"
            fi
            ok "$profile/$filename is now a private file (copied from shared)"
            ;;
        local)
            echo "${C_DIM}$profile/$filename is already private${C_RESET}"
            ;;
        broken|missing)
            touch "$path"
            ok "created empty private $profile/$filename"
            ;;
    esac
}

check_running_codex() {
    command -v pgrep >/dev/null 2>&1 || return 0
    command -v ps >/dev/null 2>&1 || return 0

    local candidates pids pid line command_name
    candidates="$(pgrep -x codex 2>/dev/null || true)"
    if [[ -z "$candidates" ]]; then
        candidates="$(pgrep -f 'codex' 2>/dev/null || true)"
    fi
    pids=""
    for pid in $candidates; do
        line="$(ps -p "$pid" -o comm=,args= 2>/dev/null || true)"
        [[ -n "$line" ]] || continue
        command_name="${line%% *}"
        command_name="${command_name##*/}"
        [[ "$command_name" == "codex" ]] || continue
        [[ "$line" =~ codex-profile|codex-find|test/runner.sh|grep|pgrep ]] && continue
        pids="${pids}${pid} "
    done
    if [[ -n "$pids" ]]; then
        echo "${C_YELLOW}warning:${C_RESET} codex process(es) still running:" >&2
        ps -p $pids -o pid,command 2>/dev/null | grep -vE 'codex-profile|codex-find' >&2 || true
        echo >&2
        echo "Switching while codex is running can corrupt OAuth refresh tokens." >&2
        echo "Quit them first, or run: ${C_CYAN}pkill -f codex${C_RESET}" >&2
        read -r -p "Continue anyway? [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || die "aborted"
    fi
}

list_profiles() {
    ensure_dirs
    local active
    active="$(active_profile)"
    local found=0

    if [[ -d "$PROFILES_DIR" ]]; then
        for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
            [[ -d "$dir" ]] || continue
            local name
            name="$(basename "$dir")"
            [[ "$name" == "_shared" ]] && continue
            if ! is_valid_profile_name "$name"; then
                warn_invalid_profile_dir "$name"
                continue
            fi
            found=1

            local marker="  "
            [[ "$name" == "$active" ]] && marker="${C_GREEN}*${C_RESET} "

            local status
            if profile_has_auth "$name"; then
                status="${C_GREEN}logged in${C_RESET}"
            else
                status="${C_YELLOW}empty (needs login)${C_RESET}"
            fi

            printf "%s%-20s %s\n" "$marker" "$name" "$status"
        done
    fi

    if [[ $found -eq 0 ]]; then
        echo "${C_DIM}(no profiles yet - try: codex-profile add <name>)${C_RESET}"
    fi
}

cmd_list() {
    echo "${C_BOLD}Codex profiles${C_RESET}  ${C_DIM}(at $PROFILES_DIR)${C_RESET}"
    echo
    list_profiles
}

cmd_add() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-profile add <name>"
    validate_profile_name "$name"

    ensure_dirs
    local path
    path="$(profile_path "$name")"

    if profile_exists "$name"; then
        die "profile '$name' already exists. use 'codex-profile switch $name' instead."
    fi

    mkdir -p "$path"
    chmod 700 "$path"

    # Link shared config files (config.toml) so MCP / settings are inherited.
    ensure_shared
    for f in "${SHARED_FILES[@]}"; do
        link_shared_file "$name" "$f" >/dev/null
    done

    ok "created empty profile '${C_BOLD}$name${C_RESET}' at $path"
    info "linked shared config: ${SHARED_FILES[*]}  ${C_DIM}(MCP servers etc. are inherited)${C_RESET}"
    echo
    echo "Next steps:"
    echo "  ${C_CYAN}codex-profile switch $name${C_RESET}"
    echo "  ${C_CYAN}codex${C_RESET}   ${C_DIM}# will trigger OAuth login on first run${C_RESET}"
}

cmd_import_current() {
    # Pull the user's existing ~/.codex into a named profile, then make it active.
    local name="${1:-default}"
    validate_profile_name "$name"

    ensure_dirs
    local src="$HOME/.codex"
    local dst
    dst="$(profile_path "$name")"

    [[ -d "$src" ]] || die "no existing ~/.codex to import"
    profile_exists "$name" && die "profile '$name' already exists"

    info "copying $src -> $dst"
    cp -a "$src" "$dst"

    # Promote the imported config.toml to be the shared base, and link this
    # profile to it. So future profiles created with `add` start with the same
    # MCP / settings.
    ensure_shared
    for f in "${SHARED_FILES[@]}"; do
        local imported="$dst/$f"
        local shared="$SHARED_DIR/$f"
        if [[ -f "$imported" && ! -L "$imported" ]]; then
            if [[ ! -s "$shared" ]]; then
                # Shared file is empty/new: seed it from the imported one.
                cp "$imported" "$shared"
                rm "$imported"
                ln -s "$shared" "$imported"
                info "promoted $f to shared (seeded from imported profile)"
            else
                # Shared already has content: leave imported as-is so user can
                # diff before deciding which to keep. Tell them.
                echo "${C_YELLOW}note:${C_RESET} $shared already exists; left imported $f as private."
                echo "      diff with: ${C_CYAN}diff $imported $shared${C_RESET}"
                echo "      to switch to shared: ${C_CYAN}codex-profile config link $name${C_RESET}"
            fi
        fi
    done

    write_active_profile "$name"
    ok "imported existing ~/.codex as profile '${C_BOLD}$name${C_RESET}' and made it active"
}

cmd_switch() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-profile switch <name>"
    validate_profile_name "$name"

    profile_exists "$name" || die "profile '$name' not found. try: codex-profile add $name"

    check_running_codex

    write_active_profile "$name"

    local path
    path="$(profile_path "$name")"

    ok "active profile is now ${C_BOLD}$name${C_RESET}"

    if ! profile_has_auth "$name"; then
        echo "   ${C_YELLOW}no auth.json yet - codex will prompt for OAuth login${C_RESET}"
    fi

    echo
    echo "To use it in this shell, either:"
    echo "  ${C_CYAN}eval \"\$(codex-profile env)\"${C_RESET}"
    echo "  ${C_CYAN}codex-profile run -- <cmd>${C_RESET}     ${C_DIM}# e.g. codex-profile run -- codex${C_RESET}"
    echo
    echo "Or set up the shell hook once (recommended):"
    echo "  ${C_CYAN}eval \"\$(codex-profile shell-init)\"${C_RESET}     ${C_DIM}# add to ~/.zshrc or ~/.bashrc${C_RESET}"
}

cmd_current() {
    local active
    active="$(active_profile)"
    if [[ -z "$active" ]]; then
        echo "${C_DIM}(no active profile)${C_RESET}"
        exit 0
    fi
    if profile_has_auth "$active"; then
        echo "$active"
    else
        echo "$active ${C_YELLOW}(no auth)${C_RESET}"
    fi
}

cmd_env() {
    # Emit a line you can `eval` to set CODEX_HOME in the current shell.
    local active
    active="$(active_profile)"
    [[ -n "$active" ]] || die "no active profile set"
    profile_exists "$active" || die "active profile '$active' missing on disk"
    printf 'export CODEX_HOME=%q\n' "$(profile_path "$active")"
}

cmd_run() {
    # Run a command with CODEX_HOME set to the active profile.
    local active
    active="$(active_profile)"
    [[ -n "$active" ]] || die "no active profile set"
    profile_exists "$active" || die "active profile '$active' missing on disk"

    if [[ "${1:-}" == "--" ]]; then shift; fi
    [[ $# -gt 0 ]] || die "usage: codex-profile run -- <cmd> [args...]"

    CODEX_HOME="$(profile_path "$active")" exec "$@"
}

cmd_remove() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-profile remove <name>"

    local path
    path="$(assert_safe_profile_target "$name")"

    echo "${C_YELLOW}This will delete:${C_RESET} $path"
    echo "${C_YELLOW}All auth + sessions for '$name' will be lost.${C_RESET}"
    read -r -p "Type the profile name to confirm: " confirm
    [[ "$confirm" == "$name" ]] || die "aborted"

    rm -rf "$path"
    if [[ "$(active_profile)" == "$name" ]]; then
        rm -f "$STATE_FILE"
        info "removed active state (no active profile now)"
    fi
    ok "removed profile '$name'"
}

assert_safe_profile_target() {
    local name="$1"
    validate_profile_name "$name"
    [[ "$name" != "_shared" ]] || die "cannot remove reserved profile '$name'"
    ensure_dirs
    profile_exists "$name" || die "profile '$name' not found"

    local path base target
    path="$(profile_path "$name")"
    [[ ! -L "$path" ]] || die "refusing to remove symlink profile '$name'"
    base="$(readlink -f "$PROFILES_DIR")" || die "cannot resolve profiles directory"
    target="$(readlink -f "$path")" || die "cannot resolve profile target"
    [[ "$target" != "$base" && "$target" == "$base"/* ]] || die "refusing to remove unmanaged profile target: $target"
    echo "$path"
}

cmd_config() {
    local sub="${1:-status}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
        status|"")    cmd_config_status "$@" ;;
        path)         cmd_config_path "$@" ;;
        edit)         cmd_config_edit "$@" ;;
        link)         cmd_config_link "$@" ;;
        unlink)       cmd_config_unlink "$@" ;;
        relink-all)   cmd_config_relink_all "$@" ;;
        help|-h|--help) cmd_config_help ;;
        *)            die "unknown config subcommand: $sub (try: codex-profile config help)" ;;
    esac
}

cmd_config_help() {
    cat <<EOF
${C_BOLD}codex-profile config${C_RESET} - manage shared config across profiles

${C_BOLD}USAGE${C_RESET}
  codex-profile config <subcommand>

${C_BOLD}SUBCOMMANDS${C_RESET}
  ${C_CYAN}status${C_RESET}                Show config.toml status for every profile
  ${C_CYAN}path${C_RESET}                  Print the shared config.toml path
  ${C_CYAN}edit${C_RESET}                  Open the shared config.toml in \$EDITOR
  ${C_CYAN}link${C_RESET} <profile>        Link a profile's config.toml to shared (--force to overwrite local)
  ${C_CYAN}unlink${C_RESET} <profile>      Detach a profile's config.toml from shared (make a private copy)
  ${C_CYAN}relink-all${C_RESET} [--force]  Re-link config.toml in every profile back to shared

${C_BOLD}HOW SHARING WORKS${C_RESET}
  Every profile's config.toml is a symlink to: ${C_DIM}$SHARED_CONFIG${C_RESET}
  Edit once, applies to all profiles. ${C_BOLD}auth.json is NOT shared${C_RESET}.
EOF
}

cmd_config_path() {
    ensure_shared
    echo "$SHARED_CONFIG"
}

cmd_config_edit() {
    ensure_shared
    local editor="${EDITOR:-${VISUAL:-vi}}"
    info "opening $SHARED_CONFIG in $editor"
    "$editor" "$SHARED_CONFIG"
}

cmd_config_status() {
    ensure_shared
    echo "${C_BOLD}Shared config:${C_RESET} $SHARED_CONFIG"
    if [[ -s "$SHARED_CONFIG" ]]; then
        local lines
        lines=$(wc -l < "$SHARED_CONFIG")
        local mcp_count
        mcp_count=$(grep -cE '^\[mcp_servers\.' "$SHARED_CONFIG" 2>/dev/null || echo 0)
        echo "  ${C_DIM}$lines lines, $mcp_count MCP server(s)${C_RESET}"
    else
        echo "  ${C_DIM}(empty)${C_RESET}"
    fi
    echo

    echo "${C_BOLD}Per-profile config.toml:${C_RESET}"
    local found=0
    for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
        [[ -d "$dir" ]] || continue
        local name
        name="$(basename "$dir")"
        [[ "$name" == "_shared" ]] && continue
        if ! is_valid_profile_name "$name"; then
            warn_invalid_profile_dir "$name"
            continue
        fi
        found=1

        local status
        status="$(shared_file_status "$name" "config.toml")"
        local marker
        case "$status" in
            linked)  marker="${C_GREEN}linked${C_RESET}    ${C_DIM}-> shared${C_RESET}" ;;
            local)   marker="${C_YELLOW}local${C_RESET}     ${C_DIM}(diverged from shared)${C_RESET}" ;;
            missing) marker="${C_DIM}missing${C_RESET}" ;;
            broken)  marker="${C_RED}broken${C_RESET}    ${C_DIM}(symlink target gone)${C_RESET}" ;;
        esac
        printf "  %-20s %s\n" "$name" "$marker"
    done
    [[ $found -eq 0 ]] && echo "  ${C_DIM}(no profiles)${C_RESET}"
    return 0
}

cmd_config_link() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-profile config link <profile> [--force]"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"
    local force=""
    [[ "${2:-}" == "--force" ]] && force="--force"

    if link_shared_file "$name" "config.toml" "$force"; then
        ok "$name/config.toml linked to shared"
    else
        return 1
    fi
}

cmd_config_unlink() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-profile config unlink <profile>"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"
    unlink_shared_file "$name" "config.toml"
}

cmd_config_relink_all() {
    local force=""
    [[ "${1:-}" == "--force" ]] && force="--force"
    ensure_shared

    local count=0 skipped=0 skipped_profiles=()
    for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
        [[ -d "$dir" ]] || continue
        local name
        name="$(basename "$dir")"
        [[ "$name" == "_shared" ]] && continue
        if ! is_valid_profile_name "$name"; then
            warn_invalid_profile_dir "$name"
            continue
        fi

        if link_shared_file "$name" "config.toml" "$force"; then
            count=$((count + 1))
            echo "  ${C_GREEN}linked${C_RESET}  $name"
        else
            skipped=$((skipped + 1))
            skipped_profiles+=("$name")
        fi
    done
    ok "relinked $count profile(s)"
    if [[ $skipped -gt 0 ]]; then
        echo "${C_YELLOW}skip:${C_RESET} skipped $skipped profile(s): ${skipped_profiles[*]}" >&2
        return 1
    fi
}

cmd_shell_init() {
    # Sets CODEX_HOME for every new shell, based on the active profile.
    cat <<'EOF'
# --- codex-profile shell integration ---
_codex_profile_apply() {
    local active_file="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/.active"
    if [[ -f "$active_file" ]]; then
        local _name
        _name="$(cat "$active_file" 2>/dev/null)"
        if [[ -n "$_name" && "$_name" =~ ^[a-zA-Z0-9_-]+$ && "$_name" != "_shared" && -d "${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/$_name" ]]; then
            export CODEX_HOME="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/$_name"
        fi
    fi
}
_codex_profile_apply
# Optional: show active profile in your prompt.
# For zsh, you can add:  PROMPT='%F{cyan}[${CODEX_HOME##*/}]%f '"$PROMPT"
# For bash, you can add: PS1='\[\e[36m\][${CODEX_HOME##*/}]\[\e[0m\] '"$PS1"
# --- end codex-profile ---
EOF
}

cmd_help() {
    cat <<EOF
${C_BOLD}codex-profile${C_RESET} - switch between multiple Codex CLI accounts

${C_BOLD}USAGE${C_RESET}
  codex-profile <command> [args]

${C_BOLD}COMMANDS${C_RESET}
  ${C_CYAN}list${C_RESET}                       Show all profiles (* = active)
  ${C_CYAN}current${C_RESET}                    Print the active profile name
  ${C_CYAN}add${C_RESET} <name>                 Create a new empty profile (login on next codex run)
  ${C_CYAN}import-current${C_RESET} [name]      Import existing ~/.codex as a profile (default: 'default')
  ${C_CYAN}switch${C_RESET} <name>              Make <name> the active profile (no re-login)
  ${C_CYAN}remove${C_RESET} <name>              Delete a profile and all its credentials
  ${C_CYAN}config${C_RESET} <subcommand>        Manage shared config.toml (MCP servers etc.) - see: config help
  ${C_CYAN}env${C_RESET}                        Print 'export CODEX_HOME=...' for eval
  ${C_CYAN}run${C_RESET} -- <cmd> [args]        Run a command with the active profile's CODEX_HOME
  ${C_CYAN}shell-init${C_RESET}                 Print a snippet to eval in ~/.zshrc / ~/.bashrc
  ${C_CYAN}help${C_RESET}                       Show this help

${C_BOLD}SHARED VS PRIVATE${C_RESET}
  ${C_DIM}Shared across all profiles (via symlink):${C_RESET}  config.toml (MCP servers, model defaults)
  ${C_DIM}Private to each profile:${C_RESET}                  auth.json, sessions/, history.jsonl, cache

${C_BOLD}TYPICAL FLOW${C_RESET}
  ${C_DIM}# first time: bring your existing login in${C_RESET}
  codex-profile import-current work

  ${C_DIM}# add another account (empty -> codex will OAuth on first run)${C_RESET}
  codex-profile add personal
  codex-profile switch personal
  codex-profile run -- codex          ${C_DIM}# triggers OAuth in the browser${C_RESET}

  ${C_DIM}# switch back, no re-login${C_RESET}
  codex-profile switch work
  codex-profile run -- codex

${C_BOLD}PROFILES LOCATION${C_RESET}
  $PROFILES_DIR
EOF
}

# --- dispatcher -------------------------------------------------------------
main() {
    local cmd="${1:-help}"
    [[ $# -gt 0 ]] && shift || true

    case "$cmd" in
        list|ls)              cmd_list "$@" ;;
        current|active)       cmd_current "$@" ;;
        add|new)              cmd_add "$@" ;;
        import-current|import) cmd_import_current "$@" ;;
        switch|use)           cmd_switch "$@" ;;
        remove|rm|delete)     cmd_remove "$@" ;;
        env)                  cmd_env "$@" ;;
        run|exec)             cmd_run "$@" ;;
        config)               cmd_config "$@" ;;
        shell-init|init)      cmd_shell_init "$@" ;;
        help|-h|--help)       cmd_help ;;
        *)                    die "unknown command: $cmd (try: codex-profile help)" ;;
    esac
}

main "$@"
