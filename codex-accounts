#!/usr/bin/env bash
# codex-accounts: switch between Codex CLI accounts through auth-only defaults
#
# Each profile stores its own auth.json under ~/.codex-profiles/<name>.
# Full CODEX_HOME compatibility remains available under `codex-accounts home`.

set -euo pipefail

PROFILES_DIR="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}"
STATE_FILE="$PROFILES_DIR/.active"
SHARED_DIR="$PROFILES_DIR/_shared"
REMOVED_DIR="$PROFILES_DIR/_removed"
SHARED_CONFIG="$SHARED_DIR/config.toml"

# Files we share across all profiles via symlink.
# config.toml: MCP servers, model defaults, approval policies, etc.
# (Authentication state in auth.json is intentionally NOT shared.)
SHARED_FILES=("config.toml")
PROFILE_NAME_PATTERN='^[a-zA-Z0-9_-]+$'

# --- colors (only when stdout is a tty) -------------------------------------
if [[ -t 1 ]]; then
    C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
    C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'
    C_CYAN=$'\033[36m'; C_RESET=$'\033[0m'
else
    C_BOLD=""; C_DIM=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_CYAN=""; C_RESET=""
fi

die()  { echo "${C_RED}error:${C_RESET} $*" >&2; exit 1; }
info() { echo "${C_CYAN}->${C_RESET} $*"; }
ok()   { echo "${C_GREEN}ok${C_RESET}  $*"; }

ensure_dirs() {
    mkdir -p "$PROFILES_DIR"
}

is_valid_profile_name() {
    local name="${1:-}"
    [[ -n "$name" ]] || return 1
    [[ "$name" != "_shared" ]] || return 1
    [[ "$name" != "_removed" ]] || return 1
    [[ "$name" =~ $PROFILE_NAME_PATTERN ]]
}

validate_profile_name() {
    local name="${1:-}"
    is_valid_profile_name "$name" || die "name must be alphanumeric / dash / underscore and not reserved"
}

warn_invalid_profile_dir() {
    echo "${C_YELLOW}warning:${C_RESET} skipping invalid profile directory: $1" >&2
}

profile_path() {
    validate_profile_name "$1"
    echo "$PROFILES_DIR/$1"
}

removed_profiles_dir() {
    echo "$REMOVED_DIR"
}

ensure_removed_profiles_dir() {
    mkdir -p "$(removed_profiles_dir)"
    chmod 700 "$(removed_profiles_dir)" 2>/dev/null || true
}

new_removed_profile_name() {
    local name="$1"
    validate_profile_name "$name"
    printf '%s-removed-%s-%s' "$name" "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

removed_profile_path() {
    local name="$1"
    echo "$(removed_profiles_dir)/$(new_removed_profile_name "$name")"
}

profile_exists() {
    validate_profile_name "$1"
    [[ -d "$(profile_path "$1")" ]]
}

profile_has_auth() {
    validate_profile_name "$1"
    [[ -f "$(profile_path "$1")/auth.json" ]]
}

auth_active_profile() {
    local native
    native="$(native_auth_file)"
    [[ -f "$native" ]] || return 0
    [[ -d "$PROFILES_DIR" ]] || return 0

    local dir name match=""
    for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
        [[ -d "$dir" ]] || continue
        name="$(basename "$dir")"
        [[ "$name" == "_shared" || "$name" == "_removed" ]] && continue
        is_valid_profile_name "$name" || continue
        [[ -f "$(profile_auth_file "$name")" ]] || continue
        if cmp -s "$native" "$(profile_auth_file "$name")"; then
            if [[ -n "$match" ]]; then
                return 0
            fi
            match="$name"
        fi
    done
    [[ -n "$match" ]] && echo "$match"
}

active_profile() {
    [[ -f "$STATE_FILE" ]] || return 0

    local active
    active="$(cat "$STATE_FILE" 2>/dev/null || true)"
    [[ -n "$active" ]] || return 0
    if ! is_valid_profile_name "$active"; then
        die "active profile state is invalid: $active"
    fi
    echo "$active"
}

write_active_profile() {
    local name="$1"
    validate_profile_name "$name"
    ensure_dirs

    local tmp
    tmp="$(mktemp "$PROFILES_DIR/.active.tmp.XXXXXX")"
    if ! printf '%s\n' "$name" > "$tmp"; then
        rm -f "$tmp"
        die "failed to write active profile state"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    if ! mv -f "$tmp" "$STATE_FILE"; then
        rm -f "$tmp"
        die "failed to update active profile state"
    fi
}

native_codex_dir() {
    echo "$HOME/.codex"
}

native_auth_file() {
    echo "$(native_codex_dir)/auth.json"
}

profile_auth_file() {
    local name="$1"
    echo "$(profile_path "$name")/auth.json"
}

auth_backup_dir() {
    echo "$SHARED_DIR/auth-backups"
}

ensure_auth_backup_dir() {
    mkdir -p "$(auth_backup_dir)"
    chmod 700 "$(auth_backup_dir)" 2>/dev/null || true
}

new_auth_backup_name() {
    printf 'auth-%s-%s.json' "$(date -u +%Y%m%dT%H%M%SZ)" "$$"
}

is_auth_backup_name() {
    local name="${1:-}"
    [[ "$name" =~ ^auth-[0-9]{8}T[0-9]{6}Z-[0-9]+\.json$ ]]
}

list_auth_backups() {
    local dir
    dir="$(auth_backup_dir)"
    [[ -d "$dir" ]] || return 0

    local path name
    for path in "$dir"/auth-*.json; do
        [[ -f "$path" && ! -L "$path" ]] || continue
        name="$(basename "$path")"
        is_auth_backup_name "$name" || continue
        printf '%s\n' "$path"
    done | sort
}

latest_auth_backup() {
    list_auth_backups | tail -1
}

safe_auth_backup_path() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "backup name required"
    [[ "$name" != *"/"* && "$name" != *".."* ]] || die "unsafe backup name: $name"
    is_auth_backup_name "$name" || die "invalid backup name: $name"

    local path
    path="$(auth_backup_dir)/$name"
    [[ -f "$path" ]] || die "backup not found: $name"
    [[ ! -L "$path" ]] || die "refusing symlink backup: $name"
    echo "$path"
}

backup_auth_file() {
    local src
    src="$(native_auth_file)"
    if [[ ! -f "$src" ]]; then
        echo "No existing native auth.json to back up."
        return 0
    fi

    ensure_auth_backup_dir
    local backup_path
    backup_path="$(auth_backup_dir)/$(new_auth_backup_name)"
    cp "$src" "$backup_path"
    chmod 600 "$backup_path" 2>/dev/null || true
    echo "Backed up native auth.json to:"
    echo "  $backup_path"
}

copy_auth_without_leaking() {
    local source="$1" target="$2"
    [[ -f "$source" ]] || die "auth source missing: $source"
    mkdir -p "$(dirname "$target")"
    cp "$source" "$target"
    chmod 600 "$target" 2>/dev/null || true
}

print_auth_required_paths() {
    local name="$1"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"

    echo "Auth-required files:"
    echo "  auth.json"
    echo
    echo "Native auth target:"
    echo "  $(native_auth_file)"
    echo "Profile auth source:"
    echo "  $(profile_auth_file "$name")"
    echo "Backup directory:"
    echo "  $(auth_backup_dir)"
}

preview_auth_switch() {
    local name="$1"
    print_auth_required_paths "$name"
}

# --- shared config helpers --------------------------------------------------

ensure_shared() {
    mkdir -p "$SHARED_DIR"
    [[ -f "$SHARED_CONFIG" ]] || touch "$SHARED_CONFIG"
}

# Status of a shared file inside a profile:
#   "linked"  : symlink pointing at the shared file
#   "local"   : regular file (overrides shared)
#   "missing" : file does not exist
#   "broken"  : symlink to wrong/non-existent target
shared_file_status() {
    local profile="$1" filename="$2"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    if [[ -L "$path" ]]; then
        local actual
        actual="$(readlink -f "$path" 2>/dev/null || true)"
        local expected
        expected="$(readlink -f "$target" 2>/dev/null || true)"
        if [[ -n "$actual" && "$actual" == "$expected" ]]; then
            echo "linked"
        else
            echo "broken"
        fi
    elif [[ -f "$path" ]]; then
        echo "local"
    else
        echo "missing"
    fi
}

# Link a profile's file to the shared one.
# If the profile already has a regular file, refuse unless --force.
link_shared_file() {
    local profile="$1" filename="$2" force="${3:-}"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    ensure_shared
    [[ -f "$target" ]] || touch "$target"

    local status
    status="$(shared_file_status "$profile" "$filename")"

    case "$status" in
        linked)
            return 0  # already linked, no-op
            ;;
        local)
            if [[ "$force" != "--force" ]]; then
                echo "${C_YELLOW}skip:${C_RESET} $profile/$filename is a local file (use --force to overwrite)" >&2
                return 1
            fi
            rm -f "$path"
            ;;
        broken)
            rm -f "$path"
            ;;
        missing)
            : # nothing to clean
            ;;
    esac

    ln -s "$target" "$path"
}

# Detach a profile's file from shared and make it a private copy.
unlink_shared_file() {
    local profile="$1" filename="$2"
    validate_profile_name "$profile"
    local path="$(profile_path "$profile")/$filename"
    local target="$SHARED_DIR/$filename"

    local status
    status="$(shared_file_status "$profile" "$filename")"

    case "$status" in
        linked)
            rm -f "$path"
            if [[ -f "$target" ]]; then
                cp "$target" "$path"
            else
                touch "$path"
            fi
            ok "$profile/$filename is now a private file (copied from shared)"
            ;;
        local)
            echo "${C_DIM}$profile/$filename is already private${C_RESET}"
            ;;
        broken|missing)
            touch "$path"
            ok "created empty private $profile/$filename"
            ;;
    esac
}

check_running_codex() {
    command -v pgrep >/dev/null 2>&1 || return 0
    command -v ps >/dev/null 2>&1 || return 0

    local candidates pids pid line command_name
    candidates="$(pgrep -x codex 2>/dev/null || true)"
    if [[ -z "$candidates" ]]; then
        candidates="$(pgrep -f 'codex' 2>/dev/null || true)"
    fi
    pids=""
    for pid in $candidates; do
        line="$(ps -p "$pid" -o comm=,args= 2>/dev/null || true)"
        [[ -n "$line" ]] || continue
        command_name="${line%% *}"
        command_name="${command_name##*/}"
        [[ "$command_name" == "codex" ]] || continue
        [[ "$line" =~ codex-accounts|codex-find|test/runner.sh|grep|pgrep ]] && continue
        pids="${pids}${pid} "
    done
    if [[ -n "$pids" ]]; then
        echo "${C_YELLOW}warning:${C_RESET} codex process(es) still running:" >&2
        ps -p $pids -o pid,command 2>/dev/null | grep -vE 'codex-accounts|codex-find' >&2 || true
        echo >&2
        echo "Switching while codex is running can corrupt OAuth refresh tokens." >&2
        echo "Quit them first, or run: ${C_CYAN}pkill -f codex${C_RESET}" >&2
        read -r -p "Continue anyway? [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || die "aborted"
    fi
}

list_profiles() {
    ensure_dirs
    local auth_active full_active
    auth_active="$(auth_active_profile)"
    full_active="$(active_profile)"
    local found=0

    if [[ -d "$PROFILES_DIR" ]]; then
        for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
            [[ -d "$dir" ]] || continue
            local name
            name="$(basename "$dir")"
            [[ "$name" == "_shared" || "$name" == "_removed" ]] && continue
            if ! is_valid_profile_name "$name"; then
                warn_invalid_profile_dir "$name"
                continue
            fi
            found=1

            local marker="  "
            if [[ -n "$auth_active" ]]; then
                [[ "$name" == "$auth_active" ]] && marker="${C_GREEN}*${C_RESET} "
            else
                [[ "$name" == "$full_active" ]] && marker="${C_GREEN}*${C_RESET} "
            fi

            local status
            if profile_has_auth "$name"; then
                status="${C_GREEN}logged in${C_RESET}"
            else
                status="${C_YELLOW}empty (needs login)${C_RESET}"
            fi

            printf "%s%-20s %s\n" "$marker" "$name" "$status"
        done
    fi

    if [[ $found -eq 0 ]]; then
        echo "${C_DIM}(no profiles yet - try: codex-accounts add <name>)${C_RESET}"
    fi
}

cmd_list() {
    echo "${C_BOLD}Codex profiles${C_RESET}  ${C_DIM}(at $PROFILES_DIR, * = current native auth)${C_RESET}"
    echo
    list_profiles
}

cmd_add() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts add <name>"
    validate_profile_name "$name"

    ensure_dirs
    local path
    path="$(profile_path "$name")"

    if profile_exists "$name"; then
        die "profile '$name' already exists. use 'codex-accounts switch $name' instead."
    fi

    mkdir -p "$path"
    chmod 700 "$path"

    # Link shared config files (config.toml) so MCP / settings are inherited.
    ensure_shared
    for f in "${SHARED_FILES[@]}"; do
        link_shared_file "$name" "$f" >/dev/null
    done

    ok "created empty profile '${C_BOLD}$name${C_RESET}' at $path"
    info "linked shared config: ${SHARED_FILES[*]}  ${C_DIM}(MCP servers etc. are inherited)${C_RESET}"
    echo
    echo "Next steps:"
    echo "  ${C_CYAN}codex-accounts home switch $name${C_RESET}"
    echo "  ${C_CYAN}codex-accounts home run -- codex${C_RESET}   ${C_DIM}# one-time OAuth into this profile${C_RESET}"
    echo "  ${C_CYAN}unset CODEX_HOME && codex-accounts switch $name${C_RESET}   ${C_DIM}# auth-only switch after login${C_RESET}"
}

cmd_import_current() {
    # Pull the user's existing ~/.codex into a named profile, then make it active.
    local name="${1:-default}"
    validate_profile_name "$name"

    ensure_dirs
    local src="$HOME/.codex"
    local dst
    dst="$(profile_path "$name")"

    [[ -d "$src" ]] || die "no existing ~/.codex to import"
    profile_exists "$name" && die "profile '$name' already exists"

    info "copying $src -> $dst"
    cp -a "$src" "$dst"

    # Promote the imported config.toml to be the shared base, and link this
    # profile to it. So future profiles created with `add` start with the same
    # MCP / settings.
    ensure_shared
    for f in "${SHARED_FILES[@]}"; do
        local imported="$dst/$f"
        local shared="$SHARED_DIR/$f"
        if [[ -f "$imported" && ! -L "$imported" ]]; then
            if [[ ! -s "$shared" ]]; then
                # Shared file is empty/new: seed it from the imported one.
                cp "$imported" "$shared"
                rm "$imported"
                ln -s "$shared" "$imported"
                info "promoted $f to shared (seeded from imported profile)"
            else
                # Shared already has content: leave imported as-is so user can
                # diff before deciding which to keep. Tell them.
                echo "${C_YELLOW}note:${C_RESET} $shared already exists; left imported $f as private."
                echo "      diff with: ${C_CYAN}diff $imported $shared${C_RESET}"
                echo "      to switch to shared: ${C_CYAN}codex-accounts config link $name${C_RESET}"
            fi
        fi
    done

    write_active_profile "$name"
    ok "imported existing ~/.codex as profile '${C_BOLD}$name${C_RESET}' and made it active"
}

cmd_home_switch() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts home switch <name>"
    validate_profile_name "$name"

    profile_exists "$name" || die "profile '$name' not found. try: codex-accounts add $name"

    check_running_codex

    write_active_profile "$name"

    local path
    path="$(profile_path "$name")"

    ok "active profile is now ${C_BOLD}$name${C_RESET}"

    if ! profile_has_auth "$name"; then
        echo "   ${C_YELLOW}no auth.json yet - codex will prompt for OAuth login${C_RESET}"
    fi

    echo
    echo "To use full CODEX_HOME mode in this shell, either:"
    echo "  ${C_CYAN}eval \"\$(codex-accounts home env)\"${C_RESET}"
    echo "  ${C_CYAN}codex-accounts home run -- <cmd>${C_RESET}     ${C_DIM}# e.g. codex-accounts home run -- codex${C_RESET}"
    echo
    echo "Auth-only default switch remains:"
    echo "  ${C_CYAN}codex-accounts switch $name${C_RESET}"
}

cmd_switch() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts switch <name>"
    cmd_auth_switch "$name"
}

cmd_home_current() {
    local active
    active="$(active_profile)"
    if [[ -z "$active" ]]; then
        echo "${C_DIM}(no active profile)${C_RESET}"
        exit 0
    fi
    if profile_has_auth "$active"; then
        echo "$active"
    else
        echo "$active ${C_YELLOW}(no auth)${C_RESET}"
    fi
}

cmd_home_env() {
    # Emit a line you can `eval` to set CODEX_HOME in the current shell.
    local active
    active="$(active_profile)"
    [[ -n "$active" ]] || die "no active profile set"
    profile_exists "$active" || die "active profile '$active' missing on disk"
    printf 'export CODEX_HOME=%q\n' "$(profile_path "$active")"
}

cmd_home_run() {
    # Run a command with CODEX_HOME set to the active profile.
    local active
    active="$(active_profile)"
    [[ -n "$active" ]] || die "no active profile set"
    profile_exists "$active" || die "active profile '$active' missing on disk"

    if [[ "${1:-}" == "--" ]]; then shift; fi
    [[ $# -gt 0 ]] || die "usage: codex-accounts home run -- <cmd> [args...]"

    CODEX_HOME="$(profile_path "$active")" exec "$@"
}

cmd_remove() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts remove <name>"

    local path archive_path
    path="$(assert_safe_profile_target "$name")"
    archive_path="$(removed_profile_path "$name")"

    echo "${C_YELLOW}This will deactivate profile:${C_RESET} $path"
    echo "${C_YELLOW}Profile data will be preserved at:${C_RESET} $archive_path"
    read -r -p "Type the profile name to confirm: " confirm
    [[ "$confirm" == "$name" ]] || die "aborted"

    ensure_removed_profiles_dir
    [[ ! -e "$archive_path" ]] || die "removed profile archive already exists: $archive_path"
    mv "$path" "$archive_path"
    if [[ "$(active_profile)" == "$name" ]]; then
        rm -f "$STATE_FILE"
        info "removed active state (no active profile now)"
    fi
    ok "deactivated profile '$name'"
    echo "Profile data preserved at:"
    echo "  $archive_path"
}

assert_safe_profile_target() {
    local name="$1"
    validate_profile_name "$name"
    [[ "$name" != "_shared" ]] || die "cannot remove reserved profile '$name'"
    [[ "$name" != "_removed" ]] || die "cannot remove reserved profile '$name'"
    ensure_dirs
    profile_exists "$name" || die "profile '$name' not found"

    local path base target
    path="$(profile_path "$name")"
    [[ ! -L "$path" ]] || die "refusing to remove symlink profile '$name'"
    base="$(readlink -f "$PROFILES_DIR")" || die "cannot resolve profiles directory"
    target="$(readlink -f "$path")" || die "cannot resolve profile target"
    [[ "$target" != "$base" && "$target" == "$base"/* ]] || die "refusing to remove unmanaged profile target: $target"
    echo "$path"
}

cmd_config() {
    local sub="${1:-status}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
        status|"")    cmd_config_status "$@" ;;
        path)         cmd_config_path "$@" ;;
        edit)         cmd_config_edit "$@" ;;
        link)         cmd_config_link "$@" ;;
        unlink)       cmd_config_unlink "$@" ;;
        relink-all)   cmd_config_relink_all "$@" ;;
        help|-h|--help) cmd_config_help ;;
        *)            die "unknown config subcommand: $sub (try: codex-accounts config help)" ;;
    esac
}

cmd_config_help() {
    cat <<EOF
${C_BOLD}codex-accounts config${C_RESET} - manage shared config across profiles

${C_BOLD}USAGE${C_RESET}
  codex-accounts config <subcommand>

${C_BOLD}SUBCOMMANDS${C_RESET}
  ${C_CYAN}status${C_RESET}                Show config.toml status for every profile
  ${C_CYAN}path${C_RESET}                  Print the shared config.toml path
  ${C_CYAN}edit${C_RESET}                  Open the shared config.toml in \$EDITOR
  ${C_CYAN}link${C_RESET} <profile>        Link a profile's config.toml to shared (--force to overwrite local)
  ${C_CYAN}unlink${C_RESET} <profile>      Detach a profile's config.toml from shared (make a private copy)
  ${C_CYAN}relink-all${C_RESET} [--force]  Re-link config.toml in every profile back to shared

${C_BOLD}HOW SHARING WORKS${C_RESET}
  Every profile's config.toml is a symlink to: ${C_DIM}$SHARED_CONFIG${C_RESET}
  Edit once, applies to all profiles. ${C_BOLD}auth.json is NOT shared${C_RESET}.
EOF
}

cmd_config_path() {
    ensure_shared
    echo "$SHARED_CONFIG"
}

cmd_config_edit() {
    ensure_shared
    local editor="${EDITOR:-${VISUAL:-vi}}"
    info "opening $SHARED_CONFIG in $editor"
    "$editor" "$SHARED_CONFIG"
}

cmd_config_status() {
    ensure_shared
    echo "${C_BOLD}Shared config:${C_RESET} $SHARED_CONFIG"
    if [[ -s "$SHARED_CONFIG" ]]; then
        local lines
        lines=$(wc -l < "$SHARED_CONFIG")
        local mcp_count
        mcp_count=$(grep -cE '^\[mcp_servers\.' "$SHARED_CONFIG" 2>/dev/null || echo 0)
        echo "  ${C_DIM}$lines lines, $mcp_count MCP server(s)${C_RESET}"
    else
        echo "  ${C_DIM}(empty)${C_RESET}"
    fi
    echo

    echo "${C_BOLD}Per-profile config.toml:${C_RESET}"
    local found=0
    for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
        [[ -d "$dir" ]] || continue
        local name
        name="$(basename "$dir")"
        [[ "$name" == "_shared" || "$name" == "_removed" ]] && continue
        if ! is_valid_profile_name "$name"; then
            warn_invalid_profile_dir "$name"
            continue
        fi
        found=1

        local status
        status="$(shared_file_status "$name" "config.toml")"
        local marker
        case "$status" in
            linked)  marker="${C_GREEN}linked${C_RESET}    ${C_DIM}-> shared${C_RESET}" ;;
            local)   marker="${C_YELLOW}local${C_RESET}     ${C_DIM}(diverged from shared)${C_RESET}" ;;
            missing) marker="${C_DIM}missing${C_RESET}" ;;
            broken)  marker="${C_RED}broken${C_RESET}    ${C_DIM}(symlink target gone)${C_RESET}" ;;
        esac
        printf "  %-20s %s\n" "$name" "$marker"
    done
    [[ $found -eq 0 ]] && echo "  ${C_DIM}(no profiles)${C_RESET}"
    return 0
}

cmd_config_link() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts config link <profile> [--force]"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"
    local force=""
    [[ "${2:-}" == "--force" ]] && force="--force"

    if link_shared_file "$name" "config.toml" "$force"; then
        ok "$name/config.toml linked to shared"
    else
        return 1
    fi
}

cmd_config_unlink() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts config unlink <profile>"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"
    unlink_shared_file "$name" "config.toml"
}

cmd_config_relink_all() {
    local force=""
    [[ "${1:-}" == "--force" ]] && force="--force"
    ensure_shared

    local count=0 skipped=0 skipped_profiles=()
    for dir in "$PROFILES_DIR"/*/ "$PROFILES_DIR"/.[!.]*/; do
        [[ -d "$dir" ]] || continue
        local name
        name="$(basename "$dir")"
        [[ "$name" == "_shared" || "$name" == "_removed" ]] && continue
        if ! is_valid_profile_name "$name"; then
            warn_invalid_profile_dir "$name"
            continue
        fi

        if link_shared_file "$name" "config.toml" "$force"; then
            count=$((count + 1))
            echo "  ${C_GREEN}linked${C_RESET}  $name"
        else
            skipped=$((skipped + 1))
            skipped_profiles+=("$name")
        fi
    done
    ok "relinked $count profile(s)"
    if [[ $skipped -gt 0 ]]; then
        echo "${C_YELLOW}skip:${C_RESET} skipped $skipped profile(s): ${skipped_profiles[*]}" >&2
        return 1
    fi
}

cmd_auth() {
    local sub="${1:-help}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
        paths)          cmd_auth_paths "$@" ;;
        switch)         cmd_auth_switch "$@" ;;
        backups)        cmd_auth_backups "$@" ;;
        restore)        cmd_auth_restore "$@" ;;
        revert)         cmd_auth_revert "$@" ;;
        prune-backups)  cmd_auth_prune_backups "$@" ;;
        help|-h|--help|"") cmd_auth_help ;;
        *)              die "unknown auth subcommand: $sub (try: codex-accounts auth help)" ;;
    esac
}

cmd_auth_help() {
    cat <<EOF
${C_BOLD}codex-accounts auth${C_RESET} - manage minimal Codex auth replacement

${C_BOLD}USAGE${C_RESET}
  codex-accounts auth <subcommand>

${C_BOLD}SUBCOMMANDS${C_RESET}
  ${C_CYAN}paths${C_RESET} <profile>       Preview auth-required paths without reading token contents
  ${C_CYAN}switch${C_RESET} <profile>      Replace native auth.json from profile auth.json with backup
  ${C_CYAN}backups${C_RESET}               List managed native auth backups without reading contents
  ${C_CYAN}restore${C_RESET} [backup]      Restore latest or named native auth backup
  ${C_CYAN}revert${C_RESET}                Restore latest managed native auth backup
  ${C_CYAN}prune-backups${C_RESET} --keep <count>
                         Delete older managed auth backups after confirmation
  ${C_CYAN}help${C_RESET}                  Show auth subcommand usage

${C_BOLD}SAFETY MODEL${C_RESET}
  Minimal auth commands operate on auth.json only. They do not copy sessions,
  history, logs, cache, or other Codex runtime state.
  Top-level switch/use are auth-only aliases. Full CODEX_HOME compatibility mode
  is available under codex-accounts home <subcommand>.
EOF
}

cmd_auth_paths() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts auth paths <profile>"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"
    print_auth_required_paths "$name"
}

cmd_auth_switch() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: codex-accounts auth switch <profile>"
    validate_profile_name "$name"
    profile_exists "$name" || die "profile '$name' not found"

    local source target
    source="$(profile_auth_file "$name")"
    target="$(native_auth_file)"
    [[ -f "$source" ]] || die "profile '$name' has no auth.json"

    check_running_codex
    preview_auth_switch "$name"
    backup_auth_file
    copy_auth_without_leaking "$source" "$target"
    ok "native auth.json replaced from profile '$name'"
}

cmd_auth_backups() {
    local backups
    backups="$(list_auth_backups)"
    if [[ -z "$backups" ]]; then
        echo "No auth backups found."
        echo "Backup directory:"
        echo "  $(auth_backup_dir)"
        return 0
    fi

    local latest path name size marker
    latest="$(printf '%s\n' "$backups" | tail -1)"
    echo "Auth backups:"
    while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        name="$(basename "$path")"
        size="$(wc -c < "$path" | tr -d ' ')"
        marker=" "
        [[ "$path" == "$latest" ]] && marker="*"
        printf "%s %s  %s bytes  %s\n" "$marker" "$name" "$size" "$path"
    done <<< "$backups"
}

cmd_auth_restore() {
    local requested="${1:-}"
    local backup_path
    if [[ -n "$requested" ]]; then
        backup_path="$(safe_auth_backup_path "$requested")"
    else
        backup_path="$(latest_auth_backup)"
        [[ -n "$backup_path" ]] || die "no auth backups found"
    fi

    local target
    target="$(native_auth_file)"
    copy_auth_without_leaking "$backup_path" "$target"
    echo "Restored native auth.json from:"
    echo "  $backup_path"
    echo "Native auth target:"
    echo "  $target"
}

cmd_auth_revert() {
    [[ -z "${1:-}" ]] || die "usage: codex-accounts auth revert"

    local backup_path
    backup_path="$(latest_auth_backup)"
    [[ -n "$backup_path" ]] || die "no auth backups found"

    local target
    target="$(native_auth_file)"
    copy_auth_without_leaking "$backup_path" "$target"
    echo "Reverted native auth.json from latest backup:"
    echo "  $backup_path"
    echo "Native auth target:"
    echo "  $target"
}

cmd_auth_prune_backups() {
    [[ "${1:-}" == "--keep" && -n "${2:-}" ]] || die "usage: codex-accounts auth prune-backups --keep <count>"
    local keep="$2"
    [[ "$keep" =~ ^[0-9]+$ ]] || die "--keep must be a non-negative integer"
    [[ -z "${3:-}" ]] || die "usage: codex-accounts auth prune-backups --keep <count>"

    local backups total stale_count
    backups="$(list_auth_backups)"
    if [[ -z "$backups" ]]; then
        echo "No auth backups found."
        return 0
    fi

    total="$(printf '%s\n' "$backups" | sed '/^$/d' | wc -l | tr -d ' ')"
    if (( total <= keep )); then
        echo "No auth backups to prune."
        echo "Keeping $total backup(s)."
        return 0
    fi

    stale_count=$((total - keep))
    echo "Auth backups selected for deletion:"
    printf '%s\n' "$backups" | head -n "$stale_count" | sed 's/^/  /'
    echo
    read -r -p "Type 'prune' to delete these backups: " confirm
    [[ "$confirm" == "prune" ]] || die "aborted"

    local removed=0 path name checked
    while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        name="$(basename "$path")"
        checked="$(safe_auth_backup_path "$name")"
        rm -f "$checked"
        removed=$((removed + 1))
    done < <(printf '%s\n' "$backups" | head -n "$stale_count")

    ok "removed $removed auth backup(s)"
}

cmd_shell_init() {
    # Sets CODEX_HOME for every new shell, based on the active profile.
    cat <<'EOF'
# --- codex-accounts shell integration ---
_codex_profile_apply() {
    local active_file="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/.active"
    if [[ -f "$active_file" ]]; then
        local _name
        _name="$(cat "$active_file" 2>/dev/null)"
        if [[ -n "$_name" && "$_name" =~ ^[a-zA-Z0-9_-]+$ && "$_name" != "_shared" && "$_name" != "_removed" && -d "${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/$_name" ]]; then
            export CODEX_HOME="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}/$_name"
        fi
    fi
}
_codex_profile_apply
# Optional: show active profile in your prompt.
# For zsh, you can add:  PROMPT='%F{cyan}[${CODEX_HOME##*/}]%f '"$PROMPT"
# For bash, you can add: PS1='\[\e[36m\][${CODEX_HOME##*/}]\[\e[0m\] '"$PS1"
# --- end codex-accounts ---
EOF
}

cmd_auth_init() {
    # Defines a shell wrapper so auth-only switch can unset CODEX_HOME in the
    # caller shell before invoking the real codex-accounts executable.
    cat <<'EOF'
# --- codex-accounts auth-only shell integration ---
codex-accounts() {
    case "${1:-}" in
        switch|use)
            unset CODEX_HOME
            command codex-accounts "$@"
            ;;
        auth)
            if [[ "${2:-}" == "switch" ]]; then
                unset CODEX_HOME
            fi
            command codex-accounts "$@"
            ;;
        *)
            command codex-accounts "$@"
            ;;
    esac
}
# --- end codex-accounts auth-only shell integration ---
EOF
}

cmd_home() {
    local sub="${1:-help}"
    [[ $# -gt 0 ]] && shift || true

    case "$sub" in
        switch|use)      cmd_home_switch "$@" ;;
        current|active)  cmd_home_current "$@" ;;
        env)             cmd_home_env "$@" ;;
        run|exec)        cmd_home_run "$@" ;;
        shell-init|init) cmd_shell_init "$@" ;;
        help|-h|--help|"") cmd_home_help ;;
        *)               die "unknown home subcommand: $sub (try: codex-accounts home help)" ;;
    esac
}

cmd_full_mode_moved() {
    local old="$1" replacement="$2"
    die "'codex-accounts $old' is full CODEX_HOME mode and moved to 'codex-accounts home $replacement'. Default switching is auth-only: codex-accounts switch <profile>"
}

cmd_home_help() {
    cat <<EOF
${C_BOLD}codex-accounts home${C_RESET} - explicit full CODEX_HOME compatibility mode

${C_BOLD}USAGE${C_RESET}
  codex-accounts home <subcommand>

${C_BOLD}SUBCOMMANDS${C_RESET}
  ${C_CYAN}switch${C_RESET} <profile>      Set active full-mode profile
  ${C_CYAN}current${C_RESET}               Print active full-mode profile
  ${C_CYAN}env${C_RESET}                   Print 'export CODEX_HOME=...' for eval
  ${C_CYAN}run${C_RESET} -- <cmd> [args]   Run a command with profile CODEX_HOME
  ${C_CYAN}shell-init${C_RESET}            Print shell hook for full-mode CODEX_HOME
  ${C_CYAN}help${C_RESET}                  Show this help

${C_BOLD}WHEN TO USE${C_RESET}
  Use this only for one-time OAuth into an empty profile or legacy workflows.
  The default identity switch is auth-only: codex-accounts switch <profile>.
EOF
}

cmd_help() {
    cat <<EOF
${C_BOLD}codex-accounts${C_RESET} - switch between multiple Codex CLI accounts

${C_BOLD}USAGE${C_RESET}
  codex-accounts <command> [args]

${C_BOLD}COMMANDS${C_RESET}
  ${C_CYAN}list${C_RESET}                       Show profiles (* = current native auth)
  ${C_CYAN}current${C_RESET}                    Moved to 'home current' for full-mode profiles
  ${C_CYAN}add${C_RESET} <name>                 Create a new empty profile (login on next codex run)
  ${C_CYAN}import-current${C_RESET} [name]      Import existing ~/.codex as a profile (default: 'default')
  ${C_CYAN}switch${C_RESET} <name>              Replace native ~/.codex/auth.json from profile auth
  ${C_CYAN}remove${C_RESET} <name>              Deactivate a profile and preserve its data
  ${C_CYAN}auth${C_RESET} <subcommand>          Manage minimal auth replacement - see: auth help
  ${C_CYAN}auth-init${C_RESET}                  Print shell wrapper for auth-only switching
  ${C_CYAN}home${C_RESET} <subcommand>          Explicit full CODEX_HOME compatibility mode
  ${C_CYAN}config${C_RESET} <subcommand>        Manage shared config.toml (MCP servers etc.) - see: config help
  ${C_CYAN}env${C_RESET}                        Moved to 'home env'
  ${C_CYAN}run${C_RESET} -- <cmd> [args]        Moved to 'home run'
  ${C_CYAN}shell-init${C_RESET}                 Moved to 'home shell-init'
  ${C_CYAN}help${C_RESET}                       Show this help

${C_BOLD}SHARED VS PRIVATE${C_RESET}
  ${C_DIM}Shared across all profiles (via symlink):${C_RESET}  config.toml (MCP servers, model defaults)
  ${C_DIM}Private to each profile:${C_RESET}                  auth.json, sessions/, history.jsonl, cache

${C_BOLD}TYPICAL FLOW${C_RESET}
  ${C_DIM}# first time: bring your existing native auth into a profile${C_RESET}
  codex-accounts import-current work

  ${C_DIM}# switch identity while keeping runtime state under ~/.codex${C_RESET}
  codex-accounts switch work

  ${C_DIM}# add another account; use full mode only for one-time OAuth${C_RESET}
  codex-accounts add personal
  codex-accounts home switch personal
  codex-accounts home run -- codex     ${C_DIM}# creates profile auth.json${C_RESET}

  ${C_DIM}# after OAuth, return to auth-only switching${C_RESET}
  codex-accounts switch personal

${C_BOLD}PROFILES LOCATION${C_RESET}
  $PROFILES_DIR
EOF
}

# --- dispatcher -------------------------------------------------------------
main() {
    local cmd="${1:-help}"
    [[ $# -gt 0 ]] && shift || true

    case "$cmd" in
        list|ls)              cmd_list "$@" ;;
        current|active)       cmd_full_mode_moved "$cmd" "$cmd" ;;
        add|new)              cmd_add "$@" ;;
        import-current|import) cmd_import_current "$@" ;;
        switch|use)           cmd_switch "$@" ;;
        remove|rm|delete)     cmd_remove "$@" ;;
        auth)                 cmd_auth "$@" ;;
        auth-init)            cmd_auth_init "$@" ;;
        home|full)            cmd_home "$@" ;;
        env)                  cmd_full_mode_moved "$cmd" "$cmd" ;;
        run|exec)             cmd_full_mode_moved "$cmd" "$cmd" ;;
        config)               cmd_config "$@" ;;
        shell-init|init)      cmd_full_mode_moved "$cmd" "$cmd" ;;
        help|-h|--help)       cmd_help ;;
        *)                    die "unknown command: $cmd (try: codex-accounts help)" ;;
    esac
}

main "$@"
